# Required
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TELEGRAM_WEBHOOK_SECRET=your_random_secret_here
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx
HF_TOKEN=hf_xxxxxxxxxxxx
DATASET_REPO=ShnekAI/telegram-bot-data
SPACE_URL=ShnekAI-telegram-bot.hf.space

# Optional: web search via Tavily
TAVILY_API_KEY=tvly-xxxxxxxxxxxx

# Optional: Reddit trends in /briefing (register a "script" app at
# https://www.reddit.com/prefs/apps — anonymous access is blocked with 403).
REDDIT_CLIENT_ID=xxxxxxxxxxxx
REDDIT_CLIENT_SECRET=xxxxxxxxxxxx

# Optional: restrict the bot to a single Telegram user. Empty = open to everyone.
ALLOWED_USER_ID=123456789

# Optional: dedicated model for /briefing (e.g. a stronger non-free model for
# long-context summaries). Empty = uses the shared MODEL_CHAIN (openrouter/free).
BRIEFING_MODEL=
